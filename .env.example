# Google Gemini (required)
GOOGLE_API_KEY=your_google_api_key
# If Gemini calls fail with "Connection refused", unset GOOGLE_GEMINI_BASE_URL in your shell

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional search providers
EXA_API_KEY=your_exa_api_key

# Defaults
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
MAX_CONCURRENT_RUNS=5

# Auth (optional — disabled by default for local dev)
AUTH_ENABLED=false
AEGIS_API_KEY=your-secret-api-key

# OpenTelemetry tracing (optional — export to Jaeger, LangFuse OTLP, Datadog, etc.)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aegis
OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
# Comma-separated key=value pairs for auth headers (e.g. LangFuse public/secret keys)
OTEL_EXPORTER_HEADERS=