# Google Gemini (required)
GOOGLE_API_KEY=your_google_api_key
# If Gemini calls fail with "Connection refused", unset GOOGLE_GEMINI_BASE_URL in your shell

# Database — SQLite for fast local dev (default); Neon for shared/staging
DATABASE_URL=sqlite:///./aegis.db
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional search providers
EXA_API_KEY=your_exa_api_key

# Defaults
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
MAX_CONCURRENT_RUNS=5

# Auth (optional — disabled by default for local dev)
AUTH_ENABLED=false
AEGIS_API_KEY=your-secret-api-key

# OpenTelemetry tracing (optional — export to Jaeger, LangFuse OTLP, Datadog, etc.)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aegis
OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
# Comma-separated key=value pairs for auth headers (e.g. LangFuse public/secret keys)
OTEL_EXPORTER_HEADERS=
# Jaeger UI base URL for trace links in the dashboard (use {trace_id} placeholder if needed)
OTEL_UI_BASE_URL=http://localhost:16686
OTEL_SAMPLE_RATE=1.0
OTEL_NODE_SPANS=true

# LangFuse via OTLP (example — use your project keys from LangFuse settings)
# OTEL_ENABLED=true
# OTEL_EXPORTER_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
# OTEL_EXPORTER_HEADERS=Authorization=Basic base64(public-key:secret-key)

# Presidio entity-based PII detection (requires: pip install presidio-analyzer presidio-anonymizer)
# python -m spacy download en_core_web_sm
PRESIDIO_ENABLED=false

# Run execution: inline (default) or worker (API enqueues, worker process executes)
RUN_EXECUTION_MODE=inline
RUN_WORKER_POLL_SECONDS=2

# Rate limiting (when AUTH_ENABLED=true)
RATE_LIMIT_PER_MINUTE=120

# Data retention (disabled by default)
RETENTION_ENABLED=false
RUN_RETENTION_DAYS=90

# Pgvector retrieval (PostgreSQL + CREATE EXTENSION vector)
PGVECTOR_ENABLED=false